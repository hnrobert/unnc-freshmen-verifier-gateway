{
  "name": "unnc-freshmen-verifier-gateway",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant Nuxt + SQLite verify gateway — organizations register, customize their own bilingual verify page (i18n, images, welcome markdown), and verify live against the UNNC admission portal.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "db:run": "tsx --tsconfig server/tsconfig.json server/scripts/runMigration.ts",
    "db:revert": "tsx --tsconfig server/tsconfig.json server/scripts/revertMigration.ts",
    "db:generate": "tsx --tsconfig server/tsconfig.json server/scripts/generateMigration.ts",
    "db:check": "tsx --tsconfig server/tsconfig.json server/scripts/checkMigration.ts",
    "db:seed": "tsx --tsconfig server/tsconfig.json server/db/seed.ts",
    "db:sync": "tsx server/scripts/syncMigrations.ts",
    "test": "tsx scripts/selftest.ts",
    "postinstall": "nuxt prepare && pnpm db:sync",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,vue,md,css,json}": "prettier --write"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@vue/server-renderer": "3.5.39",
    "@vueuse/core": "^14.3.0",
    "better-sqlite3": "^12.11.1",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.3.0",
    "nodemailer": "^9.0.3",
    "nuxt": "^4.4.8",
    "picomatch": "^4.0.5",
    "pngjs": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "tailwind-merge": "^3.6.0",
    "typeorm": "^1.1.0",
    "ua-parser-js": "^2.0.10",
    "vue-chartjs": "^5.3.4",
    "vue-i18n": "^11.4.6",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/picomatch": "^4.0.3",
    "@types/pngjs": "^6.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.3.7"
  }
}
