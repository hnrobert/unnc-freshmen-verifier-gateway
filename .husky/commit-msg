#!/bin/sh

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Allow merge commits without validation
if echo "$commit_msg" | grep -qE "^Merge"; then
	exit 0
fi

# Check compliance with gitflow convention: type: message
valid_types="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"
if ! echo "$commit_msg" | grep -qE "^($valid_types): .+"; then
	echo "Commit message does not follow the convention!"
	echo ""
	echo "It must use one of the following formats:"
	echo "  feat: new feature"
	echo "  fix: bug fix"
	echo "  docs: documentation update"
	echo "  style: code formatting"
	echo "  refactor: code refactoring"
	echo "  perf: performance improvement"
	echo "  test: test related"
	echo "  build: build system"
	echo "  ci: CI/CD configuration"
	echo "  chore: miscellaneous"
	echo "  revert: revert a commit"
	echo ""
	echo "Or a merge commit starting with \"Merge\""
	echo ""
	echo "Current commit message:"
	echo "  $commit_msg"
	exit 1
fi

exit 0
